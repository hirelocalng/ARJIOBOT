# ArjioBot backend environment variables.
# Railway sets PORT itself; the Procfile maps it into API_PORT below, so you
# do not need to set API_PORT manually on Railway. Set the rest via the
# Railway dashboard's Variables tab (this file is documentation only; it is
# never read by the app).

API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Optional PostgreSQL persistence for settings (bot_settings table) and
# saved exchange accounts (exchange_accounts table) - see
# arjiobot/database/session.py. If unset, the app falls back to its
# original data/*.json files, which do NOT survive a Railway redeploy
# (ephemeral filesystem) - settings/accounts reset to defaults on every
# deploy without this set. Tables are created automatically on first
# connection; bot_settings is seeded from this file's other variables
# (ADAPTER_MODE, DEFAULT_RISK_AMOUNT, MAX_LEVERAGE) on first run.
DATABASE_URL=

# Dashboard login gate (api/auth.py). Set both on Railway or the dashboard
# has no real password / signed session secret.
ARJIOBOT_DASHBOARD_PASSWORD=
ARJIOBOT_DASHBOARD_SECRET=

# Encrypts stored Bitget credentials (exchange/account_vault.py). Storing
# accounts in Postgres via DATABASE_URL does NOT make this optional: the
# encrypted ciphertext is only as durable as the key that decrypts it. Without
# this set, the key falls back to a local file under data/ that will NOT
# survive a Railway redeploy (ephemeral filesystem) - any previously saved
# encrypted credentials, in Postgres or the JSON file, would become
# permanently unreadable (a new random key every redeploy can't decrypt
# ciphertext from the previous one). Set a real random value (24+ chars) on
# Railway - this one env var is required regardless of which persistence
# backend is active.
ARJIOBOT_CREDENTIAL_ENCRYPTION_KEY=

ADAPTER_MODE=MOCK
LIVE_TRADING_ENABLED=false

BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

DEFAULT_RISK_AMOUNT=25
MAX_LEVERAGE=10
MAX_OPEN_TRADES=3
MAX_DAILY_LOSS=100
MAX_WEEKLY_LOSS=300
