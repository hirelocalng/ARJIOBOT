APP_ENV=development
API_HOST=127.0.0.1
API_PORT=8000
LOG_LEVEL=INFO
FRONTEND_PORT=5173

# Optional PostgreSQL persistence for settings and saved exchange accounts -
# see backend/arjiobot/database/session.py. Falls back to data/*.json files
# if unset (does not survive an ephemeral deployment filesystem).
DATABASE_URL=

# Dashboard login gate (api/auth.py) and credential vault encryption key
# (exchange/account_vault.py). Without ARJIOBOT_CREDENTIAL_ENCRYPTION_KEY,
# the key falls back to a local file under data/ that will not survive an
# ephemeral deployment filesystem - required regardless of whether
# DATABASE_URL is set, since the encrypted ciphertext (wherever it's stored)
# is only as durable as the key that decrypts it.
ARJIOBOT_DASHBOARD_PASSWORD=
ARJIOBOT_DASHBOARD_SECRET=
ARJIOBOT_CREDENTIAL_ENCRYPTION_KEY=

ADAPTER_MODE=MOCK
LIVE_TRADING_ENABLED=false
DEFAULT_TIMEFRAME_PROFILE=DEFAULT_16_12_8
STRATEGY_PROFILE=PROFILE_F
SELECTED_RR_PROFILE=RR_1_5
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSPHRASE=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
DEFAULT_RISK_AMOUNT=25
MAX_LEVERAGE=10
MAX_OPEN_TRADES=3
MAX_DAILY_LOSS=100
MAX_WEEKLY_LOSS=300
